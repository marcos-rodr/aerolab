# ╔══════════════════════════════════════════════════════════════╗
# ║                    AeroLab — .gitignore                     ║
# ║        Configuração de segurança para Git                   ║
# ╚══════════════════════════════════════════════════════════════╝

# ─── Python / Backend ────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.so
*.egg
*.egg-info/
dist/
build/
*.whl

# Ambiente virtual Python
venv/
.venv/
env/
ENV/

# ─── Node.js / Frontend ─────────────────────────────────────
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# Build output
frontend/dist/
*.tsbuildinfo

# ─── Variáveis de Ambiente & Segredos ───────────────────────
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
.env*.local
*.pem
*.key
*.cert

# ─── IDEs e Editores ────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo
*~
.project
.settings/
.classpath

# ─── Sistema Operacional ────────────────────────────────────
.DS_Store
Thumbs.db
ehthumbs.db
Desktop.ini
*.lnk

# ─── Logs e Temporários ─────────────────────────────────────
*.log
logs/
tmp/
temp/
*.tmp
*.bak
*.cache

# ─── Cobertura de Testes ─────────────────────────────────────
coverage/
htmlcov/
.coverage
.pytest_cache/
.mypy_cache/
